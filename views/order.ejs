<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= siteName %> - 订单详情</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div class="container narrow">
    <header class="site-header">
      <h1>订单详情</h1>
      <a class="link-btn" href="/">返回首页</a>
    </header>

    <%- include('_msg_modal') %>

    <% if (!order) { %>
      <div class="card">
        <h3>订单不存在</h3>
      </div>
    <% } else { %>
      <%
        function orderStatusText(status) {
          if (status === 'pending_payment') return '待支付';
          if (status === 'paying') return '支付中';
          if (status === 'paid') return '已支付待发货';
          if (status === 'delivered') return '已发货';
          if (status === 'out_of_stock') return '支付成功但库存不足';
          if (status === 'pay_failed') return '支付失败';
          if (status === 'pay_closed') return '支付关闭';
          return `未知状态(${status})`;
        }

        function payStateText(state) {
          const n = Number(state);
          if (n === 0) return '未支付';
          if (n === 1) return '支付中';
          if (n === 2) return '支付成功';
          if (n === 3) return '支付失败';
          if (n === 4) return '已撤销';
          if (n === 5) return '已退款';
          if (n === 6) return '订单关闭';
          return `未知状态(${state})`;
        }

        function paySceneTitle(url) {
          const text = String(url || '').toLowerCase();
          if (text.includes('alipay')) return '支付宝扫码支付';
          if (text.includes('weixin') || text.includes('wxpay') || text.includes('wechat')) return '微信扫码支付';
          return '扫码支付';
        }

        function resolveDisplayType(order) {
          const type = String(order.pay_data_type || '').trim().toLowerCase();
          if (type === 'payurl') return 'payurl';
          if (type === 'qrcode' || type === 'urlscheme') return 'qrcode';
          const text = String(order.pay_url || '').trim().toLowerCase();
          if (!text) return '';
          if (text.startsWith('weixin://') || text.startsWith('alipays://')) return 'qrcode';
          return 'qrcode';
        }
      %>
      <div class="card">
        <p>订单号: <strong><%= order.order_no %></strong></p>
        <p>商品: <strong><%= order.product_name %></strong></p>
        <p>金额: <strong>￥<%= (order.amount_cents / 100).toFixed(2) %></strong></p>
        <p>订单状态: <strong><%= orderStatusText(order.status) %></strong></p>
        <p>支付状态: <strong><%= payStateText(order.pay_state) %></strong></p>
        <p>下单时间: <%= order.created_at %></p>
        <% if (order.paid_at) { %><p>支付时间: <%= order.paid_at %></p><% } %>
        <% if (order.buyer_email) { %><p>邮箱: <%= order.buyer_email %></p><% } %>
        <% if (order.pay_order_id) { %><p>支付平台单号: <%= order.pay_order_id %></p><% } %>
      </div>

      <% if (order.status === 'pending_payment' || order.status === 'paying') { %>
        <div class="card warning">
          <h3>待支付</h3>
          <% if (order.pay_url) { %>
            <% const displayType = resolveDisplayType(order); %>
            <% if (displayType !== 'payurl') { %>
              <div class="pay-qrcode-wrap">
                <h4 class="pay-scene-title"><%= paySceneTitle(order.pay_url) %></h4>
                <div class="pay-qrcode-frame">
                  <img
                    id="payQrImage"
                    class="pay-qrcode-image"
                    alt="支付二维码"
                    src="https://api.qrserver.com/v1/create-qr-code/?size=240x240&data=<%= encodeURIComponent(order.pay_url) %>"
                  />
                </div>
                <p class="pay-scene-desc">请使用支付宝扫码完成支付</p>
              </div>
            <% } %>
            <div class="pay-countdown-card">
              <p class="pay-countdown-label">剩余支付时间</p>
              <p class="pay-countdown-time" id="payCountdown">30:00</p>
              <p class="pay-countdown-status" id="payingTip">等待支付...</p>
            </div>
            <% if (displayType === 'payurl') { %>
              <form method="get" action="<%= order.pay_url %>" target="_blank" class="stack-form pay-open-wrap">
                <button type="submit" id="payNowBtn">前往支付</button>
              </form>
            <% } %>
            <% if (displayType !== 'payurl') { %>
              <div class="pay-qrcode-actions">
                <button type="button" id="copyPayLinkBtn">复制二维码链接</button>
                <p class="muted" id="payQrTip">如无法扫码，请点击上方按钮复制链接后在支付应用打开。</p>
              </div>
            <% } %>
            <form method="post" action="/order/<%= order.order_no %>/check-pay" class="stack-form pay-check-wrap" id="payCheckForm">
              <button type="submit" id="payCheckBtn" disabled>我已支付，点击查单</button>
            </form>
            <p class="muted" id="payCheckHint"><%= displayType === 'payurl' ? '请先点击“前往支付”，再点击“我已支付，点击查单”。' : '扫码完成支付后，再点击“我已支付，点击查单”。' %></p>
            <script>
              (function () {
                var payBtn = document.getElementById('payNowBtn');
                var checkForm = document.getElementById('payCheckForm');
                var checkBtn = document.getElementById('payCheckBtn');
                var checkHint = document.getElementById('payCheckHint');
                var tipNode = document.getElementById('payingTip');
                var payQrImage = document.getElementById('payQrImage');
                var copyPayLinkBtn = document.getElementById('copyPayLinkBtn');
                var payQrTip = document.getElementById('payQrTip');
                var countdownNode = document.getElementById('payCountdown');
                if (!checkForm || !checkBtn || !tipNode || !countdownNode) return;

                var key = 'pay_opened_<%= order.order_no %>';
                var startKey = 'pay_poll_started_at_<%= order.order_no %>';
                var countdownTimer = null;
                var pollStartedAt = 0;
                var maxDurationMs = 30 * 60 * 1000;

                function enableCheckButton() {
                  checkBtn.disabled = false;
                  if (checkHint) {
                    checkHint.classList.add('is-hidden');
                  }
                }

                function showTip(text) {
                  tipNode.textContent = text;
                }

                function formatRemain(ms) {
                  var total = Math.max(0, Math.floor(ms / 1000));
                  var m = Math.floor(total / 60);
                  var s = total % 60;
                  return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
                }

                function updateCountdown() {
                  var remain = Math.max(0, pollStartedAt + maxDurationMs - Date.now());
                  countdownNode.textContent = formatRemain(remain);
                  if (remain <= 0) {
                    showTip('支付超时，请重新下单。');
                    if (countdownTimer) {
                      clearInterval(countdownTimer);
                      countdownTimer = null;
                    }
                  }
                }

                if (payQrImage) {
                  payQrImage.addEventListener('error', function () {
                    if (payQrTip) {
                      payQrTip.textContent = '二维码加载失败，请点击“复制二维码链接”后在微信/支付宝打开。';
                    }
                  });
                }

                if (copyPayLinkBtn) {
                  copyPayLinkBtn.addEventListener('click', function () {
                    var text = '<%= order.pay_url %>';
                    function done(msg) {
                      if (payQrTip) payQrTip.textContent = msg;
                    }
                    if (navigator.clipboard && navigator.clipboard.writeText) {
                      navigator.clipboard.writeText(text).then(function () {
                        done('二维码链接已复制。');
                      }).catch(function () {
                        done('复制失败，请手动复制链接。');
                      });
                      return;
                    }
                    var area = document.createElement('textarea');
                    area.value = text;
                    area.style.position = 'fixed';
                    area.style.opacity = '0';
                    document.body.appendChild(area);
                    area.focus();
                    area.select();
                    try {
                      document.execCommand('copy');
                      done('二维码链接已复制。');
                    } catch (_err) {
                      done('复制失败，请手动复制链接。');
                    }
                    document.body.removeChild(area);
                  });
                }

                function startCountdown() {
                  var now = Date.now();
                  if (!pollStartedAt) {
                    pollStartedAt = now;
                    try {
                      if (window.sessionStorage) {
                        var savedAt = Number(window.sessionStorage.getItem(startKey) || '0');
                        if (savedAt > 0) {
                          pollStartedAt = savedAt;
                        } else {
                          window.sessionStorage.setItem(startKey, String(now));
                        }
                      }
                    } catch (_err) {}
                  }

                  showTip('等待支付...');
                  updateCountdown();
                  if (!countdownTimer) {
                    countdownTimer = setInterval(updateCountdown, 1000);
                  }
                }

                try {
                  if (window.sessionStorage && window.sessionStorage.getItem(key) === '1') {
                    enableCheckButton();
                  }
                } catch (_err) {}

                if (payBtn) {
                  payBtn.addEventListener('click', function () {
                    enableCheckButton();
                    try {
                      if (window.sessionStorage && !window.sessionStorage.getItem(startKey)) {
                        window.sessionStorage.setItem(startKey, String(Date.now()));
                      }
                    } catch (_err) {}
                    try {
                      if (window.sessionStorage) {
                        window.sessionStorage.setItem(key, '1');
                      }
                    } catch (_err) {}
                  });
                } else {
                  enableCheckButton();
                  try {
                    if (window.sessionStorage) {
                      window.sessionStorage.setItem(key, '1');
                    }
                  } catch (_err) {}
                }

                startCountdown();
              })();
            </script>
          <% } else { %>
            <p>当前未拿到支付链接，请联系管理员检查通道配置。</p>
            <form method="post" action="/order/<%= order.order_no %>/check-pay" class="stack-form pay-check-wrap">
              <button type="submit">我已支付，点击查单</button>
            </form>
          <% } %>
        </div>
      <% } %>

      <% if (order.status === 'delivered') { %>
        <div class="card success">
          <h3>卡密已发放</h3>
          <pre class="secret" id="secretText"><%= order.delivered_card %></pre>
          <div class="secret-actions">
            <button type="button" id="copySecretBtn">复制卡密</button>
            <span class="secret-tip" id="secretTip">请先复制保存，关闭页面后可能找不到此卡密。</span>
          </div>
        </div>
        <script>
          (function () {
            var secretNode = document.getElementById('secretText');
            var copyBtn = document.getElementById('copySecretBtn');
            var tipNode = document.getElementById('secretTip');
            if (!secretNode || !copyBtn || !tipNode) return;

            var copied = false;

            function setTip(text) {
              tipNode.textContent = text;
            }

            async function copySecret() {
              var secret = secretNode.textContent || '';
              try {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                  await navigator.clipboard.writeText(secret);
                } else {
                  var area = document.createElement('textarea');
                  area.value = secret;
                  area.style.position = 'fixed';
                  area.style.opacity = '0';
                  document.body.appendChild(area);
                  area.focus();
                  area.select();
                  document.execCommand('copy');
                  document.body.removeChild(area);
                }
                copied = true;
                copyBtn.textContent = '已复制';
                setTip('卡密已复制。');
              } catch (_err) {
                setTip('复制失败，请手动选中文本复制。');
              }
            }

            copyBtn.addEventListener('click', copySecret);

            window.addEventListener('beforeunload', function (event) {
              if (copied) return;
              event.preventDefault();
              event.returnValue = '卡密未复制，关闭后可能丢失。';
              return event.returnValue;
            });
          })();
        </script>
      <% } else if (order.status === 'out_of_stock') { %>
        <div class="card warning">
          <h3>库存不足</h3>
          <p>该订单支付成功但暂未发卡，请联系管理员处理。</p>
        </div>
      <% } else if (order.status === 'pay_failed' || order.status === 'pay_closed') { %>
        <div class="card warning">
          <h3>支付未成功</h3>
          <p><%= order.pay_msg || '订单未支付成功，请重新下单。' %></p>
        </div>
      <% } %>
    <% } %>
  </div>
  <%- include('_theme_toggle') %>
</body>
</html>
