<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= siteName %> - 系统设置</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div class="container">
    <%- include('_nav') %>

    <%- include('../_msg_modal') %>

    <div class="card narrow">
      <h3>站点名称</h3>
      <form method="post" action="/admin/settings/site-name" class="stack-form">
        <input name="site_name" maxlength="60" value="<%= currentSiteName %>" required />
        <button type="submit">保存</button>
      </form>
      <p class="muted">保存后前台和后台会立即显示新名称。</p>
    </div>

    <div class="card narrow">
      <h3>订单支付设置</h3>
      <form method="post" action="/admin/settings/order-payment" class="stack-form">
        <input
          name="order_pay_expire_minutes"
          type="number"
          min="1"
          max="180"
          step="1"
          value="<%= orderPayExpireMinutes %>"
          required
        />
        <button type="submit">保存倒计时</button>
      </form>
      <p class="muted">订单支付页倒计时到 0 后，会删除未支付订单并返回首页。</p>
    </div>

    <div class="card">
      <h3>支付配置（易支付）</h3>
      <form method="post" action="/admin/settings/payment" class="stack-form">
        <label><input type="checkbox" name="enabled" <%= paymentConfig.enabled ? 'checked' : '' %> /> 启用支付通道</label>
        <input name="mapi_url" value="<%= paymentConfig.mapi_url %>" placeholder="API下单地址 mapi.php" />
        <input name="api_url" value="<%= paymentConfig.api_url %>" placeholder="API查询地址 api.php" />
        <input name="pid" value="<%= paymentConfig.pid %>" placeholder="商户ID pid" />
        <input name="key" value="<%= paymentConfig.key %>" placeholder="商户密钥 key" />
        <input name="pay_type" value="<%= paymentConfig.pay_type %>" placeholder="支付方式 type（如 alipay/wxpay）" />
        <input name="device" value="<%= paymentConfig.device %>" placeholder="设备类型 device（pc/mobile/wechat/alipay/jump）" />
        <input name="notify_url" value="<%= paymentConfig.notify_url %>" placeholder="异步回调地址（可空，默认本站/payment/notify/heisenlin）" />
        <input name="return_url" value="<%= paymentConfig.return_url %>" placeholder="同步跳转地址（可空，默认本站订单页）" />
        <input name="subject_prefix" value="<%= paymentConfig.subject_prefix %>" placeholder="订单标题前缀" />
        <button type="submit">保存支付配置</button>
      </form>
      <p class="muted">签名规则：按参数名ASCII升序拼接，过滤空值与 <code>sign/sign_type</code>，末尾直接拼接商户密钥后做MD5小写。</p>
      <p class="muted">回调返回值必须是小写 <code>success</code>。</p>
    </div>
  </div>
</body>
</html>
