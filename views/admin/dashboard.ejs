<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= siteName %> - 后台仪表盘</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div class="container">
    <%- include('_nav') %>

    <%- include('../_msg_modal') %>
    <%
      function centsToYuan(cents) {
        return (Number(cents || 0) / 100).toFixed(2);
      }

      function orderStatusText(status) {
        if (status === 'pending_payment') return '待支付';
        if (status === 'paying') return '支付中';
        if (status === 'delivered') return '已发货';
        if (status === 'out_of_stock') return '缺货待处理';
        if (status === 'pay_failed') return '支付失败';
        if (status === 'pay_closed') return '支付关闭';
        return `未知状态(${status})`;
      }
    %>

    <section class="stats">
      <div class="stat stat--products"><span>商品数</span><strong><%= stats.productCount %></strong></div>
      <div class="stat stat--stock"><span>未售卡密</span><strong><%= stats.unsoldCount %></strong></div>
      <div class="stat stat--orders"><span>总订单</span><strong><%= stats.orderCount %></strong></div>
      <div class="stat stat--delivered"><span>已发货</span><strong><%= stats.deliveredCount %></strong></div>
      <div class="stat stat--paid"><span>已支付金额</span><strong>￥<%= centsToYuan(stats.paidAmountCents) %></strong></div>
    </section>

    <div class="card">
      <h3>最新订单</h3>
      <table>
        <thead>
          <tr><th>订单号</th><th>商品</th><th>金额</th><th>状态</th><th>时间</th></tr>
        </thead>
        <tbody>
          <% latestOrders.forEach(o => { %>
            <tr>
              <td><%= o.order_no %></td>
              <td><%= o.product_name %></td>
              <td>￥<%= (o.amount_cents / 100).toFixed(2) %></td>
              <td><%= orderStatusText(o.status) %></td>
              <td><%= o.created_at %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>

