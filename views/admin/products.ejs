<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= siteName %> - 商品管理</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div class="container">
    <%- include('_nav') %>

    <%- include('../_msg_modal') %>

    <div class="card">
      <h3>新增商品</h3>
      <form method="post" action="/admin/products" class="stack-form">
        <input name="name" placeholder="商品名称" required />
        <input name="price" type="number" step="0.01" min="0" placeholder="价格（元）" required />
        <input name="sort_order" type="number" min="0" step="1" value="0" placeholder="排序值（越小越靠前）" />
        <textarea name="description" rows="2" placeholder="描述（可选）"></textarea>
        <button type="submit">创建商品</button>
      </form>
    </div>

    <div class="card">
      <h3>商品列表</h3>
      <table>
        <thead>
          <tr><th>ID</th><th>排序</th><th>名称</th><th>价格</th><th>库存</th><th>状态</th><th>操作</th></tr>
        </thead>
        <tbody>
          <% products.forEach(p => { %>
            <tr>
              <td><%= p.id %></td>
              <td>
                <form method="post" action="/admin/products/<%= p.id %>/sort" class="inline">
                  <input name="sort_order" type="number" min="0" step="1" value="<%= p.sort_order %>" style="width:90px;display:inline-block;" />
                  <button type="submit">保存</button>
                </form>
              </td>
              <td><%= p.name %></td>
              <td>￥<%= (p.price_cents / 100).toFixed(2) %></td>
              <td><%= p.stock %></td>
              <td><%= p.is_active ? '上架' : '下架' %></td>
              <td>
                <form method="post" action="/admin/products/<%= p.id %>/toggle" class="inline">
                  <button type="submit"><%= p.is_active ? '下架' : '上架' %></button>
                </form>
                <form method="post" action="/admin/products/<%= p.id %>/delete" class="inline" onsubmit="return confirm('确认删除?')">
                  <button type="submit" class="danger">删除</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>

