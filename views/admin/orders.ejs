<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= siteName %> - 订单管理</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <div class="container">
    <%- include('_nav') %>

    <%- include('../_msg_modal') %>
    <%
      function payStateText(state) {
        const n = Number(state);
        if (n === 0) return '未支付';
        if (n === 1) return '支付中';
        if (n === 2) return '支付成功';
        if (n === 3) return '支付失败';
        if (n === 4) return '已关闭';
        return `未知状态(${state})`;
      }

      function pageLink(targetPage) {
        return `/admin/orders?page=${targetPage}&page_size=${pagination.pageSize}`;
      }
    %>

    <div class="card">
      <h3>订单列表（共 <%= pagination.total %> 条）</h3>
      <form method="get" action="/admin/orders" class="filter-form">
        <div class="inline-fields">
          <label>
            每页
            <select name="page_size">
              <% pageSizeOptions.forEach(size => { %>
                <option value="<%= size %>" <%= pagination.pageSize === size ? 'selected' : '' %>><%= size %> 条</option>
              <% }) %>
            </select>
          </label>
          <label>
            页码
            <input type="number" name="page" min="1" max="<%= pagination.totalPages %>" value="<%= pagination.page %>" />
          </label>
        </div>
        <button type="submit">查询</button>
      </form>
      <form
        method="post"
        action="/admin/orders/cleanup-unpaid"
        class="filter-form"
        onsubmit="return confirm('确认清理超过指定分钟且未支付成功的订单？')"
      >
        <div class="inline-fields">
          <input type="hidden" name="page" value="<%= pagination.page %>" />
          <input type="hidden" name="page_size" value="<%= pagination.pageSize %>" />
          <label>
            清理阈值(分钟)
            <input type="number" name="expire_minutes" min="1" value="<%= cleanupExpireMinutes %>" />
          </label>
        </div>
        <button type="submit" class="danger">手动清理未支付订单</button>
      </form>
      <table>
        <thead>
          <tr><th>订单号</th><th>平台单号</th><th>商品</th><th>金额</th><th>订单状态</th><th>支付状态</th><th>邮箱</th><th>卡密</th><th>时间</th><th>操作</th></tr>
        </thead>
        <tbody>
          <% if (!orders.length) { %>
            <tr>
              <td colspan="10">暂无订单</td>
            </tr>
          <% } %>
          <% orders.forEach(o => { %>
            <tr>
              <td><%= o.order_no %></td>
              <td><%= o.pay_order_id || '-' %></td>
              <td><%= o.product_name %></td>
              <td>￥<%= (o.amount_cents / 100).toFixed(2) %></td>
              <td><%= o.status %></td>
              <td><%= payStateText(o.pay_state) %></td>
              <td><%= o.buyer_email || '-' %></td>
              <td><code><%= o.delivered_card || '-' %></code></td>
              <td><%= o.created_at %></td>
              <td>
                <form method="post" action="/admin/orders/<%= o.order_no %>/check-pay" class="inline">
                  <input type="hidden" name="page" value="<%= pagination.page %>" />
                  <input type="hidden" name="page_size" value="<%= pagination.pageSize %>" />
                  <button type="submit" <%= Number(o.pay_state) === 2 ? 'disabled' : '' %>>查单</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <div class="pager">
        <span>第 <%= pagination.page %> / <%= pagination.totalPages %> 页</span>
        <% if (pagination.page > 1) { %>
          <a class="link-btn" href="<%= pageLink(1) %>">首页</a>
          <a class="link-btn" href="<%= pageLink(pagination.page - 1) %>">上一页</a>
        <% } else { %>
          <span class="pager-disabled">首页</span>
          <span class="pager-disabled">上一页</span>
        <% } %>

        <% if (pagination.page < pagination.totalPages) { %>
          <a class="link-btn" href="<%= pageLink(pagination.page + 1) %>">下一页</a>
          <a class="link-btn" href="<%= pageLink(pagination.totalPages) %>">末页</a>
        <% } else { %>
          <span class="pager-disabled">下一页</span>
          <span class="pager-disabled">末页</span>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
